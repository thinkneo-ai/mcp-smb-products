# ThinkNEO MCP Products — Environment Variables
# Copy to .env and configure

# Shared Database (same PostgreSQL as enterprise MCP)
MCP_DB_HOST=172.17.0.1
MCP_DB_PORT=5432
MCP_DB_NAME=thinkneo_mcp
MCP_DB_USER=mcp_user
MCP_DB_PASSWORD=

# Redis
MCP_REDIS_PASSWORD=

# TNC Billing API
TNC_API_URL=http://127.0.0.1:8081

# CORS
ALLOWED_ORIGINS=https://claude.ai,https://chatgpt.com,https://copilot.microsoft.com,https://thinkneo.app

# Logging
LOG_LEVEL=INFO
DEBUG=false
